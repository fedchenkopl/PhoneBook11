<Application x:Class="PhoneBook10.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhoneBook10.ViewModels"
             xmlns:v="clr-namespace:PhoneBook10.Views">

    <Application.Resources>
        <DataTemplate DataType="{x:Type vm:ContactsListViewModel}">
            <v:ContactsListView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <v:AboutView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ContactEditViewModel}">
            <v:ContactEditView />
        </DataTemplate>
    </Application.Resources>
</Application>