<Window x:Class="PhoneBook10.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Телефонная книга"
        Height="500" Width="750"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="Контакты" Command="{Binding ShowContactsCommand}" Margin="5" Padding="15,8"/>
                <Button Content="О программе" Command="{Binding ShowAboutCommand}" Margin="5" Padding="15,8"/>
            </StackPanel>
        </Border>
        <ContentControl Content="{Binding NavigationService.CurrentViewModel}"/>
    </DockPanel>
</Window>