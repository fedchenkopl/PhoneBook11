<UserControl x:Class="PhoneBook10.Views.ContactEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Редактирование контакта" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Margin="0,5" Padding="5" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Имя:" FontWeight="SemiBold"/>
                <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,5"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="0,5" Padding="5" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Телефон:" FontWeight="SemiBold"/>
                <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,5"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,20" HorizontalAlignment="Center">
            <Button Content="Сохранить" Command="{Binding SaveCommand}" Width="100" Height="35" Margin="0,0,10,0"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="100" Height="35"/>
        </StackPanel>
    </Grid>
</UserControl>