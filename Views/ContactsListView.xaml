<UserControl x:Class="PhoneBook10.Views.ContactsListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Управление контактами" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Margin="0,5" Padding="5" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Имя:" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,5"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="0,5" Padding="5" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Телефон:" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,5"/>
                <TextBlock Text="Форматы: +7XXXXXXXXXX, 8XXXXXXXXXX, XXXXXXXXXX" FontSize="10" Foreground="Gray"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,15" HorizontalAlignment="Center">
            <Button Content="Добавить" Command="{Binding AddCommand}" Width="100" Height="35" Margin="0,0,10,0"/>
            <Button Content="Редактировать" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedContact}" Width="100" Height="35" Margin="0,0,10,0"/>
            <Button Content="Удалить" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedContact}" Width="100" Height="35"/>
        </StackPanel>

        <DataGrid Grid.Row="4" ItemsSource="{Binding Contacts}" SelectedItem="{Binding SelectedContact}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,10,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>